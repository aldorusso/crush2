{
  "name": "crush-news",
  "description": "crush.news — medio digital hispanohablante",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.types": "tsc --incremental --noEmit",
    "typecheck": "tsc --noEmit",
    "build.server": "vite build -c adapters/express/vite.config.ts",
    "start": "node server/entry.express.js",
    "deploy": "pnpm build && pnpm build.server",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "dev.start": "vite --open --mode ssr",
    "qwik": "qwik",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "node -e \"if(!process.env.CI&&process.env.NODE_ENV!=='production')require('child_process').execSync('husky',{stdio:'inherit'})\"",
    "seed": "tsx scripts/seed-content.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@eslint/js": "^9",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "20.19.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "9.32.0",
    "eslint-plugin-qwik": "^1.19.2",
    "globals": "16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.4.5",
    "typescript-eslint": "8.38.0",
    "typescript-plugin-css-modules": "latest",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.2",
    "undici": "^5",
    "web-vitals": "^5.2.0"
  }
}
